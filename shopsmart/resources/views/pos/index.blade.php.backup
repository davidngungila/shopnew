                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">SKU</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Stock</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <template x-for="product in filteredProducts" :key="product.id">
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-3">
                                        <div class="flex items-center">
                                            <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center mr-3">
                                                <template x-if="product.image">
                                                    <img :src="`/storage/${product.image}`" :alt="product.name" class="w-10 h-10 rounded object-cover">
                                                </template>
                                                <template x-if="!product.image">
                                                    <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                                                    </svg>
                                                </template>
                                            </div>
                                            <div>
                                                <div class="text-sm font-medium text-gray-900" x-text="product.name"></div>
                                                <div class="text-xs text-gray-500" x-text="product.description ? product.description.substring(0, 50) + '...' : ''"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-500" x-text="product.sku"></td>
                                    <td class="px-4 py-3 text-sm text-gray-500" x-text="product.category_name || 'Uncategorized'"></td>
                                    <td class="px-4 py-3 text-sm font-semibold text-green-600" x-text="`TZS ${formatNumber(product.selling_price)}`"></td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-1 text-xs font-semibold rounded-full"
                                              :class="product.stock_quantity <= 0 ? 'bg-red-100 text-red-800' : product.stock_quantity <= product.low_stock_alert ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800'">
                                            <span x-show="product.track_stock" x-text="`${product.stock_quantity} ${product.unit || 'units'}`"></span>
                                            <span x-show="!product.track_stock">Unlimited</span>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <button @click="addToCart(product)" :disabled="product.track_stock && product.stock_quantity <= 0" 
                                                class="px-3 py-1 bg-green-500 text-white text-xs rounded hover:bg-green-600 disabled:opacity-50 disabled:cursor-not-allowed">
                                            Add to Cart
                                        </button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Advanced Cart -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 flex flex-col" style="max-height: calc(100vh - 200px);">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-900">Cart</h2>
                <div class="flex items-center space-x-2">
                    <button @click="printReceipt()" x-show="cart.length > 0" class="text-sm text-blue-600 hover:text-blue-800">
                        ?? Print Receipt
                    </button>
                    <button @click="clearCart()" class="text-sm text-red-600 hover:text-red-800">Clear</button>
                </div>
            </div>
            
            <!-- Customer Info -->
            <div x-show="selectedCustomer" class="mb-4 p-3 bg-blue-50 rounded-lg">
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-sm font-medium text-blue-900">Customer: <span x-text="selectedCustomer.name"></span></div>
                        <div class="text-xs text-blue-700" x-text="selectedCustomer.phone"></div>
                    </div>
                    <button @click="selectedCustomer = null" class="text-blue-600 hover:text-blue-800">×</button>
                </div>
            </div>
            
            <div class="flex-1 overflow-y-auto mb-4 space-y-2" id="cartItems">
                <template x-for="(item, index) in cart" :key="index">
                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg border border-gray-200 hover:bg-gray-100 transition-colors">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center justify-between">
                                <div class="text-sm font-medium text-gray-900 truncate" x-text="item.name"></div>
                                <div class="flex items-center space-x-1">
                                    <button @click="editCartItem(index)" class="text-blue-600 hover:text-blue-800">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                    </button>
                                    <button @click="removeFromCart(index)" class="text-red-600 hover:text-red-800">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            <div class="flex items-center justify-between mt-1">
                                <div class="text-xs text-gray-500" x-text="`TZS ${formatNumber(item.selling_price)} x ${item.quantity}`"></div>
                                <div class="text-xs text-gray-500" x-text="item.sku"></div>
                            </div>
                            <div class="flex items-center justify-between mt-2">
                                <div class="text-sm font-bold text-green-600" x-text="`TZS ${formatNumber(item.selling_price * item.quantity - (item.discount || 0))}`"></div>
                                <div class="flex items-center space-x-1">
                                    <button @click="updateQuantity(index, -1)" class="px-2 py-1 bg-gray-200 rounded hover:bg-gray-300 text-sm font-semibold">-</button>
                                    <input 
                                        type="number" 
                                        x-model="item.quantity"
                                        @change="updateCartItem(index)"
                                        min="1"
                                        :max="item.track_stock ? item.stock_quantity : 9999"
                                        class="w-12 text-center text-sm border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-[#009245]"
                                    >
                                    <button @click="updateQuantity(index, 1)" class="px-2 py-1 bg-gray-200 rounded hover:bg-gray-300 text-sm font-semibold">+</button>
                                </div>
                            </div>
                            <!-- Item Discount -->
                            <div x-show="item.discount > 0" class="mt-1 text-xs text-red-600">
                                Discount: TZS <span x-text="formatNumber(item.discount)"></span>
                            </div>
                        </div>
                    </div>
                </template>
                <div x-show="cart.length === 0" class="text-center py-8 text-gray-500">
                    <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                    </svg>
                    <p class="text-lg font-medium">Cart is empty</p>
                    <p class="text-sm">Add products to get started</p>
                </div>
            </div>

            <div class="border-t border-gray-200 pt-4 space-y-3">
                <!-- Item-wise Discount -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Item Discount (%)</label>
                    <div class="flex space-x-2">
                        <button @click="applyItemDiscount(5)" class="px-2 py-1 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">5%</button>
                        <button @click="applyItemDiscount(10)" class="px-2 py-1 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">10%</button>
                        <button @click="applyItemDiscount(15)" class="px-2 py-1 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">15%</button>
                        <button @click="applyItemDiscount(20)" class="px-2 py-1 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">20%</button>
                        <input type="number" x-model="itemDiscountPercent" @input="applyItemDiscount(itemDiscountPercent)" min="0" max="100" class="flex-1 px-2 py-1 border border-gray-300 rounded text-sm" placeholder="Custom">
                    </div>
                </div>

                <!-- Cart Discount -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Cart Discount (TZS)</label>
                    <div class="flex space-x-2">
                        <input 
                            type="number" 
                            x-model="cartDiscount"
                            @input="updateTotals()"
                            min="0"
                            step="0.01"
                            class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#009245] focus:border-transparent"
                            placeholder="0.00"
                        >
                        <button @click="cartDiscount = cartSubtotal * 0.1; updateTotals()" class="px-3 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">10%</button>
                        <button @click="cartDiscount = cartSubtotal * 0.15; updateTotals()" class="px-3 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm">15%</button>
                    </div>
                </div>

                <!-- Tax Settings -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tax</label>
                    <div class="flex items-center space-x-2">
                        <input type="checkbox" x-model="taxEnabled" @change="updateTotals()" class="rounded border-gray-300">
                        <span class="text-sm text-gray-600">Enable Tax ({{ number_format($taxRate * 100, 0) }}%)</span>
                    </div>
                </div>

                <!-- Summary -->
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-gray-600">Subtotal:</span>
                        <span class="font-semibold" x-text="formatCurrency(cartSubtotal)"></span>
                    </div>
                    <div class="flex justify-between" x-show="itemDiscountTotal > 0">
                        <span class="text-gray-600">Item Discount:</span>
                        <span class="font-semibold text-green-600" x-text="`-${formatCurrency(itemDiscountTotal)}`"></span>
                    </div>
                    <div class="flex justify-between" x-show="cartDiscount > 0">
                        <span class="text-gray-600">Cart Discount:</span>
                        <span class="font-semibold text-red-600" x-text="`-${formatCurrency(cartDiscount)}`"></span>
                    </div>
                    <div class="flex justify-between" x-show="taxEnabled && cartTax > 0">
                        <span class="text-gray-600">Tax ({{ number_format($taxRate * 100, 0) }}%):</span>
                        <span class="font-semibold" x-text="formatCurrency(cartTax)"></span>
                    </div>
                    <div class="flex justify-between text-lg font-bold border-t border-gray-200 pt-2">
                        <span>Total:</span>
                        <span style="color: #009245;" x-text="formatCurrency(cartTotal)"></span>
                    </div>
                </div>

                <!-- Payment Methods -->
                <div class="space-y-2 mt-4">
                    <div class="grid grid-cols-2 gap-2">
                        <button @click="setPaymentMethod('cash')" :class="paymentMethod === 'cash' ? 'bg-green-500 text-white' : 'bg-gray-100 text-gray-700'" class="px-3 py-2 rounded-lg hover:opacity-80 text-sm font-medium">
                            ?? Cash
                        </button>
                        <button @click="setPaymentMethod('card')" :class="paymentMethod === 'card' ? 'bg-green-500 text-white' : 'bg-gray-100 text-gray-700'" class="px-3 py-2 rounded-lg hover:opacity-80 text-sm font-medium">
                            ?? Card
                        </button>
                        <button @click="setPaymentMethod('mobile_money')" :class="paymentMethod === 'mobile_money' ? 'bg-green-500 text-white' : 'bg-gray-100 text-gray-700'" class="px-3 py-2 rounded-lg hover:opacity-80 text-sm font-medium">
                            ?? Mobile Money
                        </button>
                        <button @click="setPaymentMethod('bank_transfer')" :class="paymentMethod === 'bank_transfer' ? 'bg-green-500 text-white' : 'bg-gray-100 text-gray-700'" class="px-3 py-2 rounded-lg hover:opacity-80 text-sm font-medium">
                            ?? Bank Transfer
                        </button>
                    </div>
                    
                    <button 
                        @click="openPaymentModal()"
                        :disabled="cart.length === 0 || processing"
                        class="w-full px-4 py-3 text-white rounded-lg font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                        style="background-color: #009245;"
                        :style="cart.length === 0 || processing ? 'background-color: #ccc;' : 'background-color: #009245;'"
                    >
                        <span x-show="!processing">?? Complete Sale - <span x-text="formatCurrency(cartTotal)"></span></span>
                        <span x-show="processing">Processing...</span>
                    </button>

                    <!-- Quick Actions -->
                    <div class="flex space-x-2">
                        <button @click="suspendSale()" class="flex-1 px-3 py-2 bg-yellow-100 text-yellow-700 rounded-lg hover:bg-yellow-200 text-sm">
                            ?? Suspend
                        </button>
                        <button @click="saveQuotation()" class="flex-1 px-3 py-2 bg-blue-100 text-blue-700 rounded-lg hover:bg-blue-200 text-sm">
                            ?? Save Quote
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@endsection

@section('scripts')
<script>
function advancedPosApp() {
    return {
        products: @json($products ?? []),
        filteredProducts: [],
        cart: [],
        searchQuery: '',
        selectedCategory: '',
        stockFilter: '',
        selectedCustomer: null,
        cartDiscount: 0,
        itemDiscountPercent: 0,
        itemDiscountTotal: 0,
        paymentMethod: 'cash',
        processing: false,
        taxRate: {{ $taxRate }},
        taxEnabled: true,
        viewMode: 'grid',
        
        cartSubtotal: 0,
        cartTax: 0,
        cartTotal: 0,
        
        // Modals
        quantityModalOpen: false,
        selectedProduct: null,
        quantityInput: 1,
        customerModalOpen: false,
        paymentModalOpen: false,
        customerSearch: '',
        filteredCustomers: [],
        cashReceived: 0,
        change: 0,
        
        // Held sales
        heldSales: [],

        init() {
            this.loadProducts();
            this.loadTodaySales();
            this.loadHeldSales();
            this.filterProducts();
            // Focus search on load
            this.$nextTick(() => {
                document.getElementById('productSearch')?.focus();
            });
        },

        loadProducts() {
            // Add category_name to products
            this.products = this.products.map(product => ({
                ...product,
                category_name: product.category?.name || 'Uncategorized'
            }));
            this.filteredProducts = [...this.products];
        },

        filterProducts() {
            let filtered = [...this.products];
            
            // Search filter
            if (this.searchQuery) {
                const query = this.searchQuery.toLowerCase();
                filtered = filtered.filter(product => 
                    product.name.toLowerCase().includes(query) ||
                    product.sku.toLowerCase().includes(query) ||
                    (product.description && product.description.toLowerCase().includes(query))
                );
            }
            
            // Category filter
            if (this.selectedCategory) {
                filtered = filtered.filter(product => product.category_id == this.selectedCategory);
            }
            
            // Stock filter
            if (this.stockFilter) {
                filtered = filtered.filter(product => {
                    if (this.stockFilter === 'in_stock') return product.stock_quantity > 0;
                    if (this.stockFilter === 'low_stock') return product.stock_quantity > 0 && product.stock_quantity <= product.low_stock_alert;
                    if (this.stockFilter === 'out_of_stock') return product.stock_quantity <= 0;
                    return true;
                });
            }
            
            this.filteredProducts = filtered;
        },

        addToCart(product) {
            if (product.track_stock && product.stock_quantity <= 0) {
                this.showNotification('Product is out of stock', 'error');
                return;
            }
            
            this.selectedProduct = product;
            this.quantityInput = 1;
            this.quantityModalOpen = true;
            
            this.$nextTick(() => {
                document.getElementById('quantityInput')?.focus();
            });
        },

        quickAddToCart(product, quantity = 1) {
            if (product.track_stock && product.stock_quantity < quantity) {
                this.showNotification('Insufficient stock', 'error');
                return;
            }
            
            const existingItem = this.cart.find(item => item.id === product.id);
            if (existingItem) {
                const newQuantity = existingItem.quantity + quantity;
                if (product.track_stock && newQuantity > product.stock_quantity) {
                    this.showNotification('Insufficient stock', 'error');
                    return;
                }
                existingItem.quantity = newQuantity;
            } else {
                this.cart.push({
                    id: product.id,
                    name: product.name,
                    sku: product.sku,
                    selling_price: product.selling_price,
                    quantity: quantity,
                    track_stock: product.track_stock,
                    stock_quantity: product.stock_quantity,
                    unit: product.unit,
                    discount: 0
                });
            }
            
            this.updateTotals();
            this.showNotification('Product added to cart', 'success');
        },

        confirmAddToCart() {
            if (!this.selectedProduct) return;
            
            const product = this.selectedProduct;
            const quantity = this.quantityInput;
            
            if (product.track_stock && quantity > product.stock_quantity) {
                this.showNotification('Insufficient stock', 'error');
                return;
            }
            
            this.quickAddToCart(product, quantity);
            this.quantityModalOpen = false;
            this.selectedProduct = null;
            this.quantityInput = 1;
        },

        removeFromCart(index) {
            this.cart.splice(index, 1);
            this.updateTotals();
        },

        updateQuantity(index, change) {
            const item = this.cart[index];
            const newQuantity = item.quantity + change;
            
            if (newQuantity < 1) return;
            
            if (item.track_stock && newQuantity > item.stock_quantity) {
                this.showNotification('Insufficient stock', 'error');
                return;
            }
            
            item.quantity = newQuantity;
            this.updateTotals();
        },

        updateCartItem(index) {
            const item = this.cart[index];
            
            if (item.quantity < 1) {
                item.quantity = 1;
            }
            
            if (item.track_stock && item.quantity > item.stock_quantity) {
                item.quantity = item.stock_quantity;
                this.showNotification('Insufficient stock', 'error');
            }
            
            this.updateTotals();
        },

        editCartItem(index) {
            const item = this.cart[index];
            this.selectedProduct = item;
            this.quantityInput = item.quantity;
            this.quantityModalOpen = true;
        },

        applyItemDiscount(percent) {
            this.cart.forEach(item => {
                item.discount = (item.selling_price * item.quantity) * (percent / 100);
            });
            this.updateTotals();
        },

        updateTotals() {
            // Calculate subtotal
            this.cartSubtotal = this.cart.reduce((sum, item) => {
                return sum + (item.selling_price * item.quantity);
            }, 0);
            
            // Calculate item discount total
            this.itemDiscountTotal = this.cart.reduce((sum, item) => {
                return sum + (item.discount || 0);
            }, 0);
            
            // Calculate taxable amount
            const taxableAmount = this.cartSubtotal - this.itemDiscountTotal - this.cartDiscount;
            
            // Calculate tax
            this.cartTax = this.taxEnabled ? taxableAmount * this.taxRate : 0;
            
            // Calculate total
            this.cartTotal = this.cartSubtotal - this.itemDiscountTotal - this.cartDiscount + this.cartTax;
        },

        clearCart() {
            if (this.cart.length === 0) return;
            
            if (confirm('Are you sure you want to clear the cart?')) {
                this.cart = [];
                this.updateTotals();
                this.cartDiscount = 0;
                this.itemDiscountPercent = 0;
            }
        },

        setPaymentMethod(method) {
            this.paymentMethod = method;
        },

        openPaymentModal() {
            this.paymentModalOpen = true;
            this.cashReceived = this.cartTotal;
            this.calculateChange();
        },

        calculateChange() {
            if (this.paymentMethod === 'cash') {
                this.change = Math.max(0, this.cashReceived - this.cartTotal);
            } else {
                this.change = 0;
            }
        },

        confirmPayment() {
            this.processing = true;
            
            // Simulate payment processing
            setTimeout(() => {
                this.completeSale();
            }, 2000);
        },

        completeSale() {
            // Simulate sale completion
            const saleData = {
                customer: this.selectedCustomer,
                items: this.cart,
                subtotal: this.cartSubtotal,
                discount: this.cartDiscount + this.itemDiscountTotal,
                tax: this.cartTax,
                total: this.cartTotal,
                payment_method: this.paymentMethod,
                cash_received: this.cashReceived,
                change: this.change
            };
            
            console.log('Sale completed:', saleData);
            
            // Show success message
            this.showNotification('Sale completed successfully!', 'success');
            
            // Clear cart
            this.cart = [];
            this.updateTotals();
            this.cartDiscount = 0;
            this.itemDiscountPercent = 0;
            this.selectedCustomer = null;
            
            // Close modal
            this.paymentModalOpen = false;
            this.processing = false;
            
            // Update today's sales
            this.loadTodaySales();
        },

        holdSale() {
            if (this.cart.length === 0) {
                this.showNotification('Cart is empty', 'error');
                return;
            }
            
            const heldSale = {
                id: Date.now(),
                customer: this.selectedCustomer,
                items: [...this.cart],
                total: this.cartTotal,
                created_at: new Date().toISOString()
            };
            
            this.heldSales.push(heldSale);
            this.saveHeldSales();
            
            this.cart = [];
            this.updateTotals();
            this.selectedCustomer = null;
            
            this.showNotification('Sale held successfully', 'success');
        },

        loadHeldSale() {
            if (this.heldSales.length === 0) return;
            
            // For simplicity, load the most recent held sale
            const heldSale = this.heldSales[this.heldSales.length - 1];
            
            this.cart = [...heldSale.items];
            this.selectedCustomer = heldSale.customer;
            this.updateTotals();
            
            // Remove from held sales
            this.heldSales = this.heldSales.filter(sale => sale.id !== heldSale.id);
            this.saveHeldSales();
            
            this.showNotification('Held sale loaded', 'success');
        },

        saveHeldSales() {
            localStorage.setItem('heldSales', JSON.stringify(this.heldSales));
        },

        loadHeldSales() {
            const saved = localStorage.getItem('heldSales');
            if (saved) {
                this.heldSales = JSON.parse(saved);
            }
        },

        suspendSale() {
            this.holdSale();
        },

        saveQuotation() {
            if (this.cart.length === 0) {
                this.showNotification('Cart is empty', 'error');
                return;
            }
            
            // Simulate saving quotation
            this.showNotification('Quotation saved successfully', 'success');
        },

        printReceipt() {
            if (this.cart.length === 0) {
                this.showNotification('Cart is empty', 'error');
                return;
            }
            
            // Simulate receipt printing
            window.print();
        },

        exportCart() {
            if (this.cart.length === 0) {
                this.showNotification('Cart is empty', 'error');
                return;
            }
            
            // Simulate cart export
            const cartData = {
                customer: this.selectedCustomer,
                items: this.cart,
                total: this.cartTotal
            };
            
            const dataStr = JSON.stringify(cartData, null, 2);
            const dataUri = 'data:application/json;charset=utf-8,'+ encodeURIComponent(dataStr);
            
            const exportFileDefaultName = `cart_${Date.now()}.json`;
            
            const linkElement = document.createElement('a');
            linkElement.setAttribute('href', dataUri);
            linkElement.setAttribute('download', exportFileDefaultName);
            linkElement.click();
            
            this.showNotification('Cart exported successfully', 'success');
        },

        quickAddProduct() {
            // Simulate quick add product
            this.showNotification('Quick add product feature coming soon', 'info');
        },

        openCustomerModal() {
            this.customerModalOpen = true;
            this.customerSearch = '';
            this.filterCustomers();
        },

        filterCustomers() {
            const customers = @json($customers ?? []);
            
            if (this.customerSearch) {
                const query = this.customerSearch.toLowerCase();
                this.filteredCustomers = customers.filter(customer => 
                    customer.name.toLowerCase().includes(query) ||
                    customer.phone.toLowerCase().includes(query) ||
                    (customer.email && customer.email.toLowerCase().includes(query))
                );
            } else {
                this.filteredCustomers = customers;
            }
        },

        selectCustomer(customer) {
            this.selectedCustomer = customer;
            this.customerModalOpen = false;
        },

        handleBarcodeSearch() {
            // Simulate barcode scanning
            const barcode = this.searchQuery.trim();
            if (barcode) {
                const product = this.products.find(p => p.barcode === barcode || p.sku === barcode);
                if (product) {
                    this.addToCart(product);
                    this.searchQuery = '';
                } else {
                    this.showNotification('Product not found', 'error');
                }
            }
        },

        loadTodaySales() {
            // Simulate loading today's sales
            const todaySales = Math.floor(Math.random() * 1000000) + 500000;
            document.getElementById('todaySales').textContent = `TZS ${this.formatNumber(todaySales)}`;
        },

        formatCurrency(amount) {
            return `TZS ${this.formatNumber(amount)}`;
        },

        formatNumber(amount) {
            return new Intl.NumberFormat('en-TZ', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(amount);
        },

        showNotification(message, type = 'info') {
            // Simple notification system
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 px-4 py-3 rounded-lg text-white z-50 ${
                type === 'success' ? 'bg-green-500' :
                type === 'error' ? 'bg-red-500' :
                type === 'warning' ? 'bg-yellow-500' :
                'bg-blue-500'
            }`;
            notification.textContent = message;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }
    }
}
</script>
@endsection
