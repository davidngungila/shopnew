                            <input type="number" x-model="quantityInput" @keydown.enter.prevent="confirmAddToCart()" min="1" :max="selectedProduct && selectedProduct.track_stock ? selectedProduct.stock_quantity : null" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#009245] focus:border-transparent text-center text-lg font-semibold" id="quantityInput">
